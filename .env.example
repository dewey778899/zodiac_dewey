# Copy this file to `.env` before starting the project.

# ========== AI ==========
AI_API_KEY=sk-xxxxxxxxxxxxxxxx
AI_API_URL=https://api.deepseek.com/chat/completions
AI_MODEL=deepseek-chat
AI_MAX_TOKENS=8000
AI_TIMEOUT_SECONDS=180

# ========== Database ==========
# Local and production both use SQLite.
DB_URL=jdbc:sqlite:./data/zodiac_dewey.db
DB_DRIVER=org.sqlite.JDBC
HIBERNATE_DIALECT=org.hibernate.community.dialect.SQLiteDialect
JPA_DDL_AUTO=update
HIBERNATE_USE_GET_GENERATED_KEYS=false

# ========== Rate Limit ==========
RATELIMIT_DAILY_TOTAL=200
RATELIMIT_PER_IP=3
RATELIMIT_ENABLED=true

# ========== CORS ==========
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080

# ========== Server ==========
SERVER_PORT=8080

# ========== Admin (local only) ==========
ADMIN_USERNAME=dewey
ADMIN_PASSWORD=dewey
ADMIN_SESSION_HOURS=12
