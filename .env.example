# ============ 复制为 .env 并填入真实值 ============
# 注意:.env 文件不要提交到 Git!

# ========== Claude API ==========
# 去 https://console.anthropic.com/settings/keys 创建
CLAUDE_API_KEY=sk-ant-api03-请替换为你的真实Key
CLAUDE_MODEL=claude-opus-4-5

# ========== 数据库 ==========
DB_HOST=localhost
DB_PORT=3306
DB_NAME=zodiac_dewey
DB_USER=zodiac
DB_PASSWORD=请改成强密码

# ========== 限流 ==========
# 全局每日总额度(防止 API 成本失控)
RATELIMIT_DAILY_TOTAL=200
# 单 IP 每日次数(防恶意刷)
RATELIMIT_PER_IP=3

# ========== CORS ==========
# 前端域名(用于跨域访问控制)
FRONTEND_ORIGIN=https://你的域名.com
