# Copy this file to `.env` before starting the project.

# ========== AI ==========
AI_API_KEY=sk-xxxxxxxxxxxxxxxx
AI_API_URL=https://api.deepseek.com/chat/completions
AI_MODEL=deepseek-chat
AI_MAX_TOKENS=8000
AI_TIMEOUT_SECONDS=180

# ========== Database ==========
# Local development defaults to an embedded H2 file database.
DB_URL=jdbc:h2:file:./data/zodiac_dewey;MODE=MySQL;DATABASE_TO_LOWER=TRUE;CASE_INSENSITIVE_IDENTIFIERS=TRUE;AUTO_SERVER=TRUE
DB_USER=sa
DB_PASSWORD=
DB_DRIVER=org.h2.Driver
HIBERNATE_DIALECT=org.hibernate.dialect.H2Dialect
JPA_DDL_AUTO=update

# ========== Rate Limit ==========
RATELIMIT_DAILY_TOTAL=200
RATELIMIT_PER_IP=3
RATELIMIT_ENABLED=true

# ========== CORS ==========
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080

# ========== Server ==========
SERVER_PORT=8080
H2_CONSOLE_ENABLED=true
